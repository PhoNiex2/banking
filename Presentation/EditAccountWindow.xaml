<Window x:Class="banking.Presentation.EditAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Account"
        Height="760"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Grid Margin="20">
        <Border Background="White"
                CornerRadius="18"
                Padding="25"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Edit Account"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                    <TextBlock Text="Update editable account details below"
                               FontSize="14"
                               Foreground="#64748B"
                               Margin="0,5,0,25"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left column -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="First Name" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtFirstName"
                                     Height="40"
                                     Padding="10"
                                     Margin="0,0,0,14"
                                     IsReadOnly="True"
                                     Background="#F1F5F9"/>

                            <TextBlock Text="Surname" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtSurname"
                                     Height="40"
                                     Padding="10"
                                     Margin="0,0,0,14"
                                     IsReadOnly="True"
                                     Background="#F1F5F9"/>

                            <TextBlock Text="Email" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtEmail" Height="40" Padding="10" Margin="0,0,0,14"/>

                            <TextBlock Text="Phone" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtPhone" Height="40" Padding="10" Margin="0,0,0,14"/>

                            <TextBlock Text="Address Line 1" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtAddress1" Height="40" Padding="10" Margin="0,0,0,14"/>

                            <TextBlock Text="Address Line 2" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtAddress2" Height="40" Padding="10" Margin="0,0,0,14"/>
                        </StackPanel>

                        <!-- Right column -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="City" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtCity" Height="40" Padding="10" Margin="0,0,0,14"/>

                            <TextBlock Text="County" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtCounty" Height="40" Padding="10" Margin="0,0,0,14"/>

                            <TextBlock Text="Account Type" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtAccountType"
                                     Height="40"
                                     Padding="10"
                                     Margin="0,0,0,14"
                                     IsReadOnly="True"
                                     Background="#F1F5F9"/>

                            <TextBlock Text="Account Number" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtAccountNumber"
                                     Height="40"
                                     Padding="10"
                                     Margin="0,0,0,14"
                                     IsReadOnly="True"
                                     Background="#F1F5F9"/>

                            <TextBlock Text="Sort Code" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtSortCode"
                                     Height="40"
                                     Padding="10"
                                     Margin="0,0,0,14"
                                     IsReadOnly="True"
                                     Background="#F1F5F9"/>

                            <TextBlock Text="Initial Balance" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtBalance"
                                     Height="40"
                                     Padding="10"
                                     Margin="0,0,0,14"
                                     IsReadOnly="True"
                                     Background="#F1F5F9"/>

                            <TextBlock Text="Overdraft Limit" Foreground="#475569" Margin="3,0,0,6"/>
                            <TextBox x:Name="txtOverdraft" Height="40" Padding="10" Margin="0,0,0,14"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">
                        <Button Content="Cancel"
                                Width="120"
                                Height="42"
                                Margin="0,0,10,0"
                                Background="#CBD5E1"
                                Foreground="#0F172A"
                                BorderThickness="0"
                                Click="Cancel_Click"/>

                        <Button Content="Save Changes"
                                Width="160"
                                Height="42"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                Click="SaveChanges_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>