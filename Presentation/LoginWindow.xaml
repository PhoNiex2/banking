<Window x:Class="banking.Presentation.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DBS Credit Union"
        Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F172A">

    <Grid>
        <Grid Width="350" HorizontalAlignment="Left" Background="#1E293B">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="DBS " FontSize="34" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Internal Banking System" Foreground="#94A3B8" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Margin="350,0,0,0">
            <StackPanel VerticalAlignment="Center" Margin="50">
                <TextBlock Text="Welcome Back" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,25"/>

                <TextBlock Text="Username" Foreground="#94A3B8" Margin="5,0,0,5"/>
                <Border Background="#1E293B" CornerRadius="10" Margin="0,0,0,15">
                    <TextBox x:Name="txtUsername"
                             Height="40"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             Padding="10"/>
                </Border>

                <TextBlock Text="Password" Foreground="#94A3B8" Margin="5,0,0,5"/>
                <Border Background="#1E293B" CornerRadius="10" Margin="0,0,0,20">
                    <PasswordBox x:Name="txtPassword"
                                 Height="40"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Padding="10"/>
                </Border>

                <Button Content="Login"
                        Height="45"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="Login_Click"/>

                <TextBlock x:Name="txtError"
                           Foreground="#EF4444"
                           Margin="0,15,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Grid>

        <Button Content="X"
                Width="30" Height="30"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                Background="Transparent"
                Foreground="White"
                BorderThickness="0"
                Click="Close_Click"/>
    </Grid>
</Window>