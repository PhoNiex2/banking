<Window x:Class="banking.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <DockPanel>

        <!-- Top Menu -->
        <Menu DockPanel.Dock="Top" Background="White" Foreground="#1E293B" FontSize="14">
            <MenuItem Header="File">
                <MenuItem Header="Log Out" Click="LogOut_Click"/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="Account">
                <MenuItem Header="New Account" Click="NewAccount_Click"/>
                <MenuItem Header="Edit Account" Click="EditAccount_Click"/>
                <MenuItem Header="Deposit Funds" Click="DepositFunds_Click"/>
                <MenuItem Header="Withdraw Funds" Click="WithdrawFunds_Click"/>
                <MenuItem Header="Transfer Funds" Click="TransferFunds_Click"/>
                <MenuItem Header="View Transactions" Click="ViewTransactions_Click"/>
                <MenuItem Header="Export To XML" Click="ExportToXml_Click"/>
            </MenuItem>
        </Menu>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="DBS Credit Union"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>
                    <TextBlock Text="Account Management Dashboard"
                               FontSize="14"
                               Foreground="#64748B"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Refresh"
                        Width="110"
                        Height="38"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="Refresh_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Quick Actions -->
            <WrapPanel Grid.Row="1" Margin="0,0,0,20">
                <Button Content="New Account"
                        Width="130" Height="40" Margin="0,0,10,10"
                        Background="#0F172A" Foreground="White" BorderThickness="0"
                        Click="NewAccount_Click"/>

                <Button Content="Edit Account"
                        Width="130" Height="40" Margin="0,0,10,10"
                        Background="#334155" Foreground="White" BorderThickness="0"
                        Click="EditAccount_Click"/>

                <Button Content="Deposit"
                        Width="110" Height="40" Margin="0,0,10,10"
                        Background="#16A34A" Foreground="White" BorderThickness="0"
                        Click="DepositFunds_Click"/>

                <Button Content="Withdraw"
                        Width="110" Height="40" Margin="0,0,10,10"
                        Background="#DC2626" Foreground="White" BorderThickness="0"
                        Click="WithdrawFunds_Click"/>

                <Button Content="Transfer"
                        Width="110" Height="40" Margin="0,0,10,10"
                        Background="#7C3AED" Foreground="White" BorderThickness="0"
                        Click="TransferFunds_Click"/>

                <Button Content="Transactions"
                        Width="130" Height="40" Margin="0,0,10,10"
                        Background="#EA580C" Foreground="White" BorderThickness="0"
                        Click="ViewTransactions_Click"/>
                <Button Content="Deactivate Account"
        Width="170"
        Height="40"
        Margin="0,0,10,10"
        Background="#B91C1C"
        Foreground="White"
        BorderThickness="0"
        Click="DeactivateAccount_Click"/>
            </WrapPanel>

            <!-- Summary + Search -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1 -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="16"
                        Padding="18"
                        Margin="0,0,15,0"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total Accounts"
                                   FontSize="13"
                                   Foreground="#64748B"/>
                        <TextBlock x:Name="txtTotalAccounts"
                                   Text="0"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Card 2 -->
                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="16"
                        Padding="18"
                        Margin="0,0,15,0"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Total Balance"
                                   FontSize="13"
                                   Foreground="#64748B"/>
                        <TextBlock x:Name="txtTotalBalance"
                                   Text="€0.00"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Search -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Search Accounts"
                               FontSize="13"
                               Foreground="#64748B"
                               Margin="3,0,0,6"/>
                    <TextBox x:Name="txtSearch"
                             Height="42"
                             Padding="10"
                             FontSize="14"
                             TextChanged="txtSearch_TextChanged"
                             Background="White"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"/>
                </StackPanel>
            </Grid>

            <!-- Data Grid -->
            <Border Grid.Row="3"
                    Background="White"
                    CornerRadius="18"
                    Padding="15"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">
                <DataGrid x:Name="dgAccounts"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          HeadersVisibility="Column"
          RowBackground="White"
          AlternatingRowBackground="#F8FAFC"
          GridLinesVisibility="Horizontal"
          BorderThickness="0"
          SelectionMode="Single"
          SelectionUnit="FullRow"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          CanUserResizeRows="False"
          ColumnHeaderHeight="45"
          RowHeight="40"
          FontSize="14">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="Foreground" Value="#0F172A"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,0"/>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="#0F172A"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE"/>
                                    <Setter Property="Foreground" Value="#0F172A"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Account Number"
                            Binding="{Binding AccountNumber}"
                            Width="140"/>

                        <DataGridTextColumn Header="First Name"
                            Binding="{Binding FirstName}"
                            Width="120"/>

                        <DataGridTextColumn Header="Surname"
                            Binding="{Binding Surname}"
                            Width="120"/>

                        <DataGridTextColumn Header="Email"
                            Binding="{Binding Email}"
                            Width="180"/>

                        <DataGridTextColumn Header="Phone"
                            Binding="{Binding Phone}"
                            Width="120"/>

                        <DataGridTextColumn Header="Sort Code"
                            Binding="{Binding SortCode}"
                            Width="100"/>

                        <DataGridTextColumn Header="Type"
                            Binding="{Binding AccountType}"
                            Width="100"/>

                        <DataGridTextColumn Header="Balance"
                            Binding="{Binding Balance, StringFormat={}{0:C}}"
                            Width="110"/>

                        <DataGridTextColumn Header="Overdraft"
                            Binding="{Binding OverdraftLimit, StringFormat={}{0:C}}"
                            Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </DockPanel>
</Window>