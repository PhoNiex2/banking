<Window x:Class="banking.Presentation.DepositWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Deposit Funds"
        Height="320"
        Width="460"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Grid Margin="20">
        <Border Background="White"
                CornerRadius="18"
                Padding="25"
                BorderBrush="#E2E8F0"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="Deposit Funds"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#0F172A"/>

                <TextBlock Text="Enter the amount to deposit into the selected account"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,5,0,25"/>

                <TextBlock Text="Amount"
                           Foreground="#475569"
                           Margin="3,0,0,6"/>

                <TextBox x:Name="txtAmount"
                         Height="42"
                         Padding="10"
                         Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Width="110"
                            Height="42"
                            Margin="0,0,10,0"
                            Background="#CBD5E1"
                            Foreground="#0F172A"
                            BorderThickness="0"
                            Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Deposit"
                            Width="130"
                            Height="42"
                            Background="#16A34A"
                            Foreground="White"
                            BorderThickness="0"
                            Click="Deposit_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>