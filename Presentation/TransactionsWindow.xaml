<Window x:Class="banking.Presentation.TransactionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transactions"
        Height="560"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Grid Margin="20">
        <Border Background="White"
                CornerRadius="18"
                Padding="25"
                BorderBrush="#E2E8F0"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Transaction History"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"/>
                        <TextBlock Text="View all transactions for the selected account"
                                   FontSize="14"
                                   Foreground="#64748B"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Close"
                            Width="110"
                            Height="42"
                            Background="#CBD5E1"
                            Foreground="#0F172A"
                            BorderThickness="0"
                            Click="Close_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Summary row -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#F8FAFC"
                            CornerRadius="14"
                            Padding="16"
                            Margin="0,0,15,0"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Total Transactions"
                                       FontSize="13"
                                       Foreground="#64748B"/>
                            <TextBlock x:Name="txtTransactionCount"
                                       Text="0"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="#F8FAFC"
                            CornerRadius="14"
                            Padding="16"
                            Margin="0,0,15,0"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Total Value"
                                       FontSize="13"
                                       Foreground="#64748B"/>
                            <TextBlock x:Name="txtTransactionTotal"
                                       Text="€0.00"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="Search Transactions"
                                   FontSize="13"
                                   Foreground="#64748B"
                                   Margin="3,0,0,6"/>
                        <TextBox x:Name="txtSearchTransaction"
                                 Height="42"
                                 Padding="10"
                                 FontSize="14"
                                 TextChanged="txtSearchTransaction_TextChanged"/>
                    </StackPanel>
                </Grid>

                <!-- DataGrid -->
                <Border Grid.Row="2"
                        Background="#FFFFFF"
                        CornerRadius="16"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Padding="10">
                    <DataGrid x:Name="dgTransactions"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              RowBackground="White"
                              AlternatingRowBackground="#F8FAFC"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>